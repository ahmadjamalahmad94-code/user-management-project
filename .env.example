# Copy to .env for local development. Do not commit real secrets.
HOBEHUB_LOCAL_DEMO=1
HOBEHUB_LOCAL_DEMO_SEED=0
HOBEHUB_LOCAL_DB_PATH=instance/hobehub_local_demo.sqlite3
FLASK_SECRET_KEY=replace-with-a-long-random-secret
MIKROTIK_HOTSPOT_URL=http://10.10.10.10

# Production database. Required outside local demo mode.
# DATABASE_URL=postgresql://user:password@host:5432/dbname?sslmode=require

# Optional initial admin creation. In production, set this only for first boot,
# then rotate/remove it after the account is created.
# HOBEHUB_ADMIN_USERNAME=admin
# HOBEHUB_ADMIN_PASSWORD=replace-with-a-strong-password

# ───── RADIUS API integration (app_ad2) ─────
# المسار يجب أن ينتهي بـ /app_ad2 (وليس /app_ad — التوثيق فيه خطأ)
# RADIUS_API_BASE_URL=https://example.com/app_ad2
# RADIUS_API_MASTER_KEY=replace-with-license-id
# RADIUS_API_USERNAME=replace-with-sub-admin-user   # تجنّب 'admin' المالك (يُرفض)
# RADIUS_API_PASSWORD=replace-with-plain-password   # سيتم MD5 تلقائيًا

# تفعيل وضع الاتصال الحي:
#   manual = لا اتصال (افتراضي)
#   live   = استخدم LiveRadiusClient
# RADIUS_MODE=manual
# RADIUS_API_LIVE=0

# تفعيل قراءة الـ API الفعلية (المرحلة الأولى — قراءة فقط)
# RADIUS_API_READY=0

# تفعيل عمليات الكتابة في الـ API (المرحلة الثانية — بعد اختبار كامل)
# RADIUS_API_WRITES_ENABLED=0

# للسيرفرات الذاتية التوقيع فقط:
# RADIUS_API_VERIFY_SSL=1

# Legacy AdvClient API (مهجور)
# ADV_APP_API_BASE_URL=https://example.com/app
# ADV_APP_DEFAULT_USERNAME=replace-with-service-user
# ADV_APP_DEFAULT_PASSWORD=replace-with-secret
